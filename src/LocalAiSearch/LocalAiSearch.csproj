<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net10.0-windows10.0.19041;net10.0-ios;net10.0-android;net10.0-maccatalyst</TargetFrameworks>
    <OutputType>Exe</OutputType>
    <RootNamespace>LocalAiSearch</RootNamespace>
    <AssemblyName>LocalAiSearch</AssemblyName>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Uno.WinUI" Version="5.*" />
    <PackageReference Include="Uno.Extensions.Hosting" Version="*" />
  </ItemGroup>
</Project>
