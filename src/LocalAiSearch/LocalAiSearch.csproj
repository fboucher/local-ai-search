<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net10.0-windows10.0.19041;net10.0</TargetFrameworks>
    <OutputType>Exe</OutputType>
    <RootNamespace>LocalAiSearch</RootNamespace>
    <AssemblyName>LocalAiSearch</AssemblyName>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
  </PropertyGroup>
  <!-- Skia/non-Windows: enable Uno XAML source generators and declare Page items -->
  <PropertyGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) != 'windows'">
    <IsUnoHead>true</IsUnoHead>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Uno.WinUI" Version="5.*" />
    <PackageReference Include="Uno.Extensions.Hosting" Version="*" />
  </ItemGroup>
  <ItemGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) != 'windows'">
    <Page Include="**/*.xaml" Exclude="obj/**/*.xaml" />
  </ItemGroup>
  <!-- Skia desktop renderer for net10.0 (Mac + Linux via GTK) -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
    <PackageReference Include="Uno.WinUI.Skia.Gtk" Version="5.*" />
  </ItemGroup>
</Project>
