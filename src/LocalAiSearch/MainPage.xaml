<Page x:Class="LocalAiSearch.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="White">
  <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="2*"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>
    
    <!-- Left Panel: Thumbnail Grid -->
    <Grid Grid.Column="0" Padding="10">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>
      
      <!-- Top Bar: Search and Sort -->
      <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,10">
        <TextBox x:Name="SearchBox" 
                 PlaceholderText="Search images..." 
                 Width="300"
                 Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay}"/>
        <Button Content="{x:Bind ViewModel.SortMode, Mode=OneWay}"
                Command="{x:Bind ViewModel.SortToggleCommand}">
          <ToolTipService.ToolTip>
            <ToolTip Content="Toggle sort by Date/Name"/>
          </ToolTipService.ToolTip>
        </Button>
      </StackPanel>
      
      <!-- Thumbnail Grid with Scroll -->
      <ScrollViewer Grid.Row="1" 
                    x:Name="ThumbnailScroller"
                    ViewChanged="OnScrollViewChanged">
        <GridView x:Name="ThumbnailGrid"
                  ItemsSource="{x:Bind ViewModel.DisplayedItems, Mode=OneWay}"
                  SelectionMode="Single"
                  SelectionChanged="OnThumbnailSelected"
                  IsItemClickEnabled="True">
          <GridView.ItemTemplate>
            <DataTemplate>
              <StackPanel Width="150" Height="180">
                <!-- Placeholder colored rectangle for thumbnail -->
                <Border Width="150" Height="150" 
                        Background="#FFE0E0E0"
                        BorderBrush="#FF888888"
                        BorderThickness="1">
                  <TextBlock Text="📷" 
                             FontSize="48"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Foreground="#FF666666"/>
                </Border>
                <!-- Filename label -->
                <TextBlock Text="{Binding FileName}" 
                           TextTrimming="CharacterEllipsis"
                           FontSize="11"
                           Margin="0,5,0,0"
                           TextAlignment="Center"/>
              </StackPanel>
            </DataTemplate>
          </GridView.ItemTemplate>
        </GridView>
      </ScrollViewer>
    </Grid>
    
    <!-- Right Panel: Preview and Metadata -->
    <Grid Grid.Column="1" 
          Background="#FFF5F5F5" 
          Padding="15"
          BorderBrush="#FFCCCCCC"
          BorderThickness="1,0,0,0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      
      <!-- Preview Title -->
      <TextBlock Grid.Row="0" 
                 Text="Preview" 
                 FontSize="18" 
                 FontWeight="Bold"
                 Margin="0,0,0,10"/>
      
      <!-- Full-size Preview Area -->
      <Border Grid.Row="1" 
              Background="White"
              BorderBrush="#FF888888"
              BorderThickness="1"
              Margin="0,0,0,15">
        <Grid>
          <!-- Placeholder for full preview -->
          <TextBlock Text="{x:Bind ViewModel.SelectedItem.FileName, Mode=OneWay, FallbackValue='No image selected'}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     FontSize="14"
                     Foreground="#FF666666"
                     TextWrapping="Wrap"
                     TextAlignment="Center"
                     Margin="10"/>
        </Grid>
      </Border>
      
      <!-- Metadata Panel -->
      <StackPanel Grid.Row="2" Spacing="10">
        <TextBlock Text="Metadata" 
                   FontSize="14" 
                   FontWeight="SemiBold"
                   Margin="0,0,0,5"/>
        
        <StackPanel Spacing="5">
          <TextBlock Text="Description:" 
                     FontSize="12" 
                     FontWeight="SemiBold"/>
          <TextBlock Text="{x:Bind ViewModel.SelectedItem.Description, Mode=OneWay, FallbackValue='—'}"
                     FontSize="11"
                     TextWrapping="Wrap"
                     Foreground="#FF333333"/>
        </StackPanel>
        
        <StackPanel Spacing="5">
          <TextBlock Text="Tags:" 
                     FontSize="12" 
                     FontWeight="SemiBold"/>
          <TextBlock Text="{x:Bind ViewModel.SelectedItem.Tags, Mode=OneWay, FallbackValue='—'}"
                     FontSize="11"
                     TextWrapping="Wrap"
                     Foreground="#FF333333"/>
        </StackPanel>
        
        <StackPanel Spacing="5">
          <TextBlock Text="Media Type:" 
                     FontSize="12" 
                     FontWeight="SemiBold"/>
          <TextBlock Text="{x:Bind ViewModel.SelectedItem.MediaType, Mode=OneWay, FallbackValue='—'}"
                     FontSize="11"
                     Foreground="#FF333333"/>
        </StackPanel>
        
        <StackPanel Spacing="5">
          <TextBlock Text="Created:" 
                     FontSize="12" 
                     FontWeight="SemiBold"/>
          <TextBlock Text="{x:Bind ViewModel.SelectedItem.FormattedDate, Mode=OneWay, FallbackValue='—'}"
                     FontSize="11"
                     Foreground="#FF333333"/>
        </StackPanel>
      </StackPanel>
    </Grid>
  </Grid>
</Page>
